# Copy to .env and fill in. NEVER commit .env.
# --- Django ---
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Postgres ---
POSTGRES_DB=receptionaly
POSTGRES_USER=receptionaly
POSTGRES_PASSWORD=receptionaly
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- Anthropic (Saeed to provide) ---
ANTHROPIC_API_KEY=
